# ---------------------------------------------------------------------------
# Helix — environment variables
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Required — Anthropic
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Required — Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Required — GitHub
# ---------------------------------------------------------------------------
# Personal access token with repo scope (read + write + pull requests + issues)
GITHUB_TOKEN=ghp_...

# The repository Helix will fix bugs in (owner/name format)
# Can also be set in config.yaml under github.target_repo
HELIX_GITHUB_REPO=your-org/your-repo

# ---------------------------------------------------------------------------
# Required — Sentry or Rollbar (at least one)
# ---------------------------------------------------------------------------
# Sentry: client secret from the Sentry integration settings page
SENTRY_WEBHOOK_SECRET=

# Rollbar: project read token — Helix verifies this against data.access_token
ROLLBAR_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Optional — Slack (strongly recommended)
# ---------------------------------------------------------------------------
# Bot token (xoxb-...) with chat:write scope
SLACK_BOT_TOKEN=xoxb-...

# App signing secret — used to verify Approve/Reject button payloads
SLACK_SIGNING_SECRET=

# Channel ID (C...) or name (#channel) for Slack notifications
SLACK_APPROVAL_CHANNEL=#helix-approvals

# LLM provider: "anthropic" (default) or "ollama"                                                                                                    
HELIX_PROVIDER=anthropic                                                                                                                             
HELIX_MODEL=claude-sonnet-4-6                                                                                                                        
HELIX_OLLAMA_BASE_URL=http://localhost:11434         